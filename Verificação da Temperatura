#include<DHT.h>

#defineDHTPIN D2
#defineDHTTYPE DHT11

DHTdht(DHTPIN,DHTTYPE);

void setup() {
Serial.begin(115200);
Serial.printLn("Testando DHT11...");
dht.begin();
}

void loop() {
float temp =dht.readTemperature();

if (isnan(temp)) {
Serial.printLn("Erro na leitura!");
  }else {
Serial.print("Temperatura: ");
Serial.print(temp)
Serial.printLn(" °C");
  }

delay(2000);

